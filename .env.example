# Copy this file to ".env" and fill in your key to enable the AI Analyst feature.
# The .env file is git-ignored so your key never gets committed or deployed by accident.

OPENAI_API_KEY=sk-your-key-here

# Optional: pick the model. Defaults to gpt-4o-mini (cheap + widely available).
# You can set this to another model your account has access to, e.g. gpt-4o or gpt-5.5.
OPENAI_MODEL=gpt-4o-mini
